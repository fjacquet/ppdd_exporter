# EnvironmentFile for the ppdd_exporter systemd unit.
# Supplies appliance secrets referenced as ${VAR} in config.yaml.
#
# Install:  /etc/ppdd_exporter/ppdd_exporter.env   (chmod 0600, chown root:ppdd)

PPDD1_PASSWORD=change-me
# PPDD2_PASSWORD=change-me

# Optional: only consumed if config.yaml's insecureSkipVerify references
# ${PPDD1_SKIP_CERTIFICATE}. Defaults to false (TLS verification on) when unset.
# PPDD1_SKIP_CERTIFICATE=false
