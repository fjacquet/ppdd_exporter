# Copy to .env and fill in — `.env` is gitignored, never commit real secrets.
# Compose reads .env natively, and the ppdd_exporter binary itself loads .env from
# the working directory (or next to config.yaml). Already-set environment variables
# always take precedence over .env values.

# Exporter image tag (GHCR). Pin a release for production instead of :latest.
PPDD_TAG=latest

# Hostname (or IP) of the DD appliance. config.yaml references it as ${PPDD1_HOSTNAME}.
PPDD1_HOSTNAME=dd01.example.com

# Read-only DD monitoring username. config.yaml references it as ${PPDD1_USERNAME}.
PPDD1_USERNAME=ppdd-monitor

# Password for the DD monitoring user. config.yaml references it as ${PPDD1_PASSWORD}.
# Special characters: wrap the value in single quotes so it is taken literally, e.g.
# PPDD1_PASSWORD='p@$$w0rd!#{}'. Double quotes expand $VAR and process backslashes;
# unquoted values treat " #" (space-hash) as a comment. For a literal ' use double
# quotes ("p'ass"); for a " use single quotes ('p"ass'); for both, a backslash, or a
# value starting with a quote, use passwordFile in config.yaml instead (read verbatim).
PPDD1_PASSWORD=changeme

# Grafana admin login.
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme

# Public URL Grafana is served at (your server, not localhost) — needed so login
# redirects and share links resolve correctly when accessed remotely.
GF_SERVER_ROOT_URL=http://your-server.example.com:3000
