{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "PowerProtect DD — Health & Ops",
  "uid": "ppdd-health",
  "tags": ["ppdd", "dell", "data-domain"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "links": [
    {
      "type": "dashboards",
      "tags": ["ppdd"],
      "title": "PPDD dashboards",
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "system",
        "label": "DD System",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(ppdd_system_cpu_percent, system)", "refId": "vars" },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Faults & alerts",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Failed disks",
      "description": "Sum of ppdd_disk_failed across selected systems.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(ppdd_disk_failed{system=~\"$system\"}) or vector(0)", "instant": true }
      ]
    },
    {
      "type": "bargauge",
      "title": "Active alerts by severity / class",
      "description": "Active alerts (is_active=true) grouped by severity and class.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 12, "x": 6, "y": 1 },
      "options": { "orientation": "horizontal", "displayMode": "basic", "minVizWidth": 0 },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "orange", "value": null } ] } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (severity, class) (ppdd_alerts_active{system=~\"$system\"})", "legendFormat": "{{severity}} / {{class}}", "instant": true }
      ]
    },
    {
      "type": "stat",
      "title": "Collectors up",
      "description": "Per-collector scrape health. DOWN means that module failed to collect.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [ { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_collector_up{system=~\"$system\"}", "legendFormat": "{{collector}} {{system}}", "instant": true }
      ]
    },
    {
      "type": "table",
      "title": "Failed disk detail",
      "description": "Disks currently reporting failed (ppdd_disk_failed == 1).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_disk_failed{system=~\"$system\"} == 1", "format": "table", "instant": true }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true, "Value": true },
            "indexByName": { "system": 0, "disk": 1 },
            "renameByName": { "system": "System", "disk": "Disk" }
          }
        }
      ],
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "type": "gauge",
      "title": "CPU utilization",
      "description": "ppdd_system_cpu_percent per system.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_system_cpu_percent{system=~\"$system\"}", "legendFormat": "{{system}}", "instant": true }
      ]
    },
    {
      "type": "row",
      "title": "Performance",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "title": "System throughput",
      "description": "Read and write bytes per second per system.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 15 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_system_read_bytes_per_second{system=~\"$system\"}", "legendFormat": "read {{system}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_system_write_bytes_per_second{system=~\"$system\"}", "legendFormat": "write {{system}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "CPU utilization over time",
      "description": "ppdd_system_cpu_percent trend.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent", "min": 0, "max": 100,
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 } ] }
        }
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_system_cpu_percent{system=~\"$system\"}", "legendFormat": "{{system}}" }
      ]
    }
  ]
}
