{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "title": "PowerProtect DD — Overview",
  "uid": "ppdd-overview",
  "tags": ["ppdd", "dell", "data-domain"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "templating": {
    "list": [
      {
        "name": "system",
        "label": "DD System",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(ppdd_filesystem_total_bytes, system)", "refId": "vars" },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Capacity & Deduplication",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "gauge",
      "title": "Filesystem Used %",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "100 * ppdd_filesystem_used_bytes{system=~\"$system\"} / ppdd_filesystem_total_bytes{system=~\"$system\"}",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_filesystem_used_bytes{system=~\"$system\"}", "legendFormat": "{{system}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Available",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "bytes", "color": { "mode": "fixed", "fixedColor": "green" } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_filesystem_available_bytes{system=~\"$system\"}", "legendFormat": "{{system}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Total Dedup / Compression Factor",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1, "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_compression_total_factor{system=~\"$system\"}", "legendFormat": "{{system}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Raw Capacity",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_filesystem_total_bytes{system=~\"$system\"}", "legendFormat": "{{system}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Compression Factors",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 5 },
      "fieldConfig": { "defaults": { "unit": "none", "decimals": 1, "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 5 } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_compression_global_factor{system=~\"$system\"}", "legendFormat": "global {{system}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_compression_local_factor{system=~\"$system\"}", "legendFormat": "local {{system}}" },
        { "refId": "C", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_compression_total_factor{system=~\"$system\"}", "legendFormat": "total {{system}}" },
        { "refId": "Documented", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_compression_factor{system=~\"$system\"}", "legendFormat": "documented {{system}}" }
      ]
    },
    {
      "type": "row",
      "title": "MTrees",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "bargauge",
      "title": "MTree Logical Used",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_mtree_logical_used_bytes{system=~\"$system\"}", "legendFormat": "{{mtree}}", "instant": true }
      ]
    },
    {
      "type": "table",
      "title": "MTree Detail",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "targets": [
        { "refId": "Logical", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_mtree_logical_used_bytes{system=~\"$system\"}", "format": "table", "instant": true },
        { "refId": "Physical", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_mtree_physical_used_bytes{system=~\"$system\"}", "format": "table", "instant": true },
        { "refId": "Compression", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_mtree_compression_factor{system=~\"$system\"}", "format": "table", "instant": true },
        { "refId": "Degraded", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_mtree_degraded{system=~\"$system\"}", "format": "table", "instant": true },
        { "refId": "RetentionLock", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_mtree_retention_lock_enabled{system=~\"$system\"}", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": {
              "mtree": "MTree",
              "system": "System",
              "Value #Logical": "Logical Used",
              "Value #Physical": "Physical Used",
              "Value #Compression": "Compression x",
              "Value #Degraded": "Degraded",
              "Value #RetentionLock": "Retention Lock"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "Logical Used" }, "properties": [ { "id": "unit", "value": "bytes" } ] },
          { "matcher": { "id": "byName", "options": "Physical Used" }, "properties": [ { "id": "unit", "value": "bytes" } ] },
          { "matcher": { "id": "byName", "options": "Compression x" }, "properties": [ { "id": "unit", "value": "none" }, { "id": "decimals", "value": 1 } ] },
          { "matcher": { "id": "byName", "options": "Degraded" }, "properties": [ { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "No", "color": "green" }, "1": { "text": "Yes", "color": "red" } } } ] }, { "id": "custom.cellOptions", "value": { "type": "color-text" } } ] },
          { "matcher": { "id": "byName", "options": "Retention Lock" }, "properties": [ { "id": "mappings", "value": [ { "type": "value", "options": { "0": { "text": "No", "color": "orange" }, "1": { "text": "Yes", "color": "green" } } } ] }, { "id": "custom.cellOptions", "value": { "type": "color-text" } } ] }
        ]
      }
    },
    {
      "type": "row",
      "title": "Replication",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "type": "bargauge",
      "title": "Replication Sync Lag",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 19 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 600 }, { "color": "red", "value": 3600 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_replication_sync_lag_seconds{system=~\"$system\"}", "legendFormat": "{{source}}", "instant": true }
      ]
    },
    {
      "type": "stat",
      "title": "Replication Backlog (pre-comp remaining)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 19 },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_replication_precomp_bytes_remaining{system=~\"$system\"}", "legendFormat": "{{source}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Contexts Not Normal",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(ppdd_replication_state{system=~\"$system\", state!=\"normal\"} == 1) or vector(0)", "legendFormat": "not normal" }
      ]
    },
    {
      "type": "row",
      "title": "Health & Ops",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "type": "stat",
      "title": "Failed Disks",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 27 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(ppdd_disk_failed{system=~\"$system\"})", "legendFormat": "failed" }
      ]
    },
    {
      "type": "bargauge",
      "title": "Active Alerts by Severity / Class",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 27 },
      "options": { "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": { "defaults": { "unit": "none" } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(ppdd_alerts_active{system=~\"$system\"}) by (severity, class)", "legendFormat": "{{severity}} / {{class}}", "instant": true }
      ]
    },
    {
      "type": "gauge",
      "title": "CPU Utilization",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 27 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 } ] }
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_system_cpu_percent{system=~\"$system\"}", "legendFormat": "{{system}}" }
      ]
    },
    {
      "type": "stat",
      "title": "Collectors Up",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 27 },
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_collector_up{system=~\"$system\"}", "legendFormat": "{{collector}} {{system}}", "instant": true }
      ]
    },
    {
      "type": "timeseries",
      "title": "System Throughput",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 33 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_system_read_bytes_per_second{system=~\"$system\"}", "legendFormat": "read {{system}}" },
        { "refId": "B", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_system_write_bytes_per_second{system=~\"$system\"}", "legendFormat": "write {{system}}" }
      ]
    }
  ]
}
