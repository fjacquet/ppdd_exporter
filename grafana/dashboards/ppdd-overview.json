{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "title": "PowerProtect DD — Overview",
  "uid": "ppdd-overview",
  "tags": ["ppdd", "dell", "data-domain"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "links": [
    {
      "type": "dashboards",
      "tags": ["ppdd"],
      "title": "PPDD dashboards",
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "icon": "external link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "system",
        "label": "DD System",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": { "query": "label_values(ppdd_filesystem_total_bytes, system)", "refId": "vars" },
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Fleet health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Systems reporting",
      "description": "Distinct DD systems currently exporting filesystem capacity.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 0, "y": 1 },
      "options": { "colorMode": "value", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "none", "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(group by (system) (ppdd_filesystem_total_bytes{system=~\"$system\"}))", "instant": true }
      ]
    },
    {
      "type": "stat",
      "title": "Collectors down",
      "description": "Collector modules reporting ppdd_collector_up == 0. Non-zero means a domain failed to scrape.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 3, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(ppdd_collector_up{system=~\"$system\"} == 0) or vector(0)", "instant": true }
      ]
    },
    {
      "type": "stat",
      "title": "Failed disks",
      "description": "Sum of ppdd_disk_failed across the selected systems.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 6, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(ppdd_disk_failed{system=~\"$system\"}) or vector(0)", "instant": true }
      ]
    },
    {
      "type": "stat",
      "title": "Critical alerts",
      "description": "Active alerts with severity CRITICAL (DD enum casing).",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 9, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(ppdd_alerts_active{system=~\"$system\", severity=\"CRITICAL\"}) or vector(0)", "instant": true }
      ]
    },
    {
      "type": "stat",
      "title": "Repl not NORMAL",
      "description": "MTree replication contexts whose current state is not NORMAL.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 12, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(ppdd_mtree_replication_state{system=~\"$system\", state!=\"NORMAL\"} == 1) or vector(0)", "instant": true }
      ]
    },
    {
      "type": "stat",
      "title": "Need resync",
      "description": "Replication contexts that require a resync.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 15, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(ppdd_mtree_replication_need_resync{system=~\"$system\"}) or vector(0)", "instant": true }
      ]
    },
    {
      "type": "stat",
      "title": "GC running",
      "description": "Filesystems with garbage collection / cleaning currently running.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "mode": "absolute", "steps": [ { "color": "blue", "value": null } ] } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum(ppdd_filesystem_cleaning_running{system=~\"$system\"}) or vector(0)", "instant": true }
      ]
    },
    {
      "type": "stat",
      "title": "Worst used %",
      "description": "Highest filesystem utilization across the selected systems.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 1 },
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "percent", "decimals": 1, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 } ] } } },
      "targets": [
        { "refId": "A", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "max(100 * ppdd_filesystem_used_bytes{system=~\"$system\"} / ppdd_filesystem_total_bytes{system=~\"$system\"})", "instant": true }
      ]
    },
    {
      "type": "row",
      "title": "Per-system summary",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "table",
      "title": "Systems at a glance",
      "description": "One row per DD system. Drill into Capacity / MTrees / Replication / Health via the dashboard links above.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 6 },
      "targets": [
        { "refId": "Used", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "100 * ppdd_filesystem_used_bytes{system=~\"$system\"} / ppdd_filesystem_total_bytes{system=~\"$system\"}", "format": "table", "instant": true },
        { "refId": "UsedBytes", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_filesystem_used_bytes{system=~\"$system\"}", "format": "table", "instant": true },
        { "refId": "Total", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_filesystem_total_bytes{system=~\"$system\"}", "format": "table", "instant": true },
        { "refId": "Dedup", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_compression_factor{system=~\"$system\"}", "format": "table", "instant": true },
        { "refId": "Alerts", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (system) (ppdd_alerts_active{system=~\"$system\"})", "format": "table", "instant": true },
        { "refId": "Disks", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "sum by (system) (ppdd_disk_failed{system=~\"$system\"})", "format": "table", "instant": true },
        { "refId": "ReplBad", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count by (system) (ppdd_mtree_replication_state{system=~\"$system\", state!=\"NORMAL\"} == 1)", "format": "table", "instant": true },
        { "refId": "CPU", "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "ppdd_system_cpu_percent{system=~\"$system\"}", "format": "table", "instant": true }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "indexByName": {
              "system": 0,
              "Value #Used": 1,
              "Value #UsedBytes": 2,
              "Value #Total": 3,
              "Value #Dedup": 4,
              "Value #CPU": 5,
              "Value #Alerts": 6,
              "Value #Disks": 7,
              "Value #ReplBad": 8
            },
            "renameByName": {
              "system": "System",
              "Value #Used": "Used %",
              "Value #UsedBytes": "Used",
              "Value #Total": "Total",
              "Value #Dedup": "Dedup x",
              "Value #CPU": "CPU %",
              "Value #Alerts": "Alerts",
              "Value #Disks": "Disks failed",
              "Value #ReplBad": "Repl not normal"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "auto", "cellOptions": { "type": "auto" } } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Used %" }, "properties": [ { "id": "unit", "value": "percent" }, { "id": "decimals", "value": 1 }, { "id": "custom.cellOptions", "value": { "type": "gauge", "mode": "gradient" } }, { "id": "min", "value": 0 }, { "id": "max", "value": 100 }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 85 } ] } } ] },
          { "matcher": { "id": "byName", "options": "Used" }, "properties": [ { "id": "unit", "value": "bytes" } ] },
          { "matcher": { "id": "byName", "options": "Total" }, "properties": [ { "id": "unit", "value": "bytes" } ] },
          { "matcher": { "id": "byName", "options": "Dedup x" }, "properties": [ { "id": "unit", "value": "none" }, { "id": "decimals", "value": 1 } ] },
          { "matcher": { "id": "byName", "options": "CPU %" }, "properties": [ { "id": "unit", "value": "percent" }, { "id": "decimals", "value": 0 } ] },
          { "matcher": { "id": "byName", "options": "Alerts" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-text" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 1 } ] } } ] },
          { "matcher": { "id": "byName", "options": "Disks failed" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } ] },
          { "matcher": { "id": "byName", "options": "Repl not normal" }, "properties": [ { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 1 } ] } } ] }
        ]
      }
    }
  ]
}
